/* Luqevora Website v1.2 */
:root{
  --navy:#0B1F44;--navy-2:#071735;--blue:#1463FF;--teal:#12C9C0;
  --bg:#F5F8FC;--surface:#FFFFFF;--text:#162033;--muted:#5F6B7C;
  --line:#DDE6F1;--soft-blue:#EAF1FF;--soft-teal:#E7FBF9;
  --shadow:0 18px 48px rgba(11,31,68,.10);--radius:22px;--max:1180px;
}
*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;color:var(--text);background:var(--bg);font-family:Inter,"Noto Sans JP","Hiragino Kaku Gothic ProN","Yu Gothic",system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;line-height:1.75;-webkit-font-smoothing:antialiased}
img{max-width:100%;height:auto}a{color:inherit;text-decoration:none}button,input,textarea,select{font:inherit}.container{width:min(92%,var(--max));margin-inline:auto}.narrow{width:min(92%,820px);margin-inline:auto}.skip-link{position:absolute;left:-9999px;top:12px;background:#fff;color:#000;padding:10px 14px;border-radius:8px;z-index:9999}.skip-link:focus{left:12px}.site-header{position:sticky;top:0;z-index:1000;border-bottom:1px solid rgba(221,230,241,.9);background:rgba(255,255,255,.88);backdrop-filter:blur(16px)}.header-inner{min-height:76px;display:flex;align-items:center;justify-content:space-between;gap:28px}.brand{display:flex;align-items:center;gap:12px;font-weight:850;color:var(--navy);letter-spacing:-.035em;font-size:25px}.brand img{width:42px;height:42px;border-radius:12px}.main-nav{display:flex;align-items:center;gap:22px;font-size:14px;font-weight:680}.main-nav a{padding:9px 0;color:#33415A}.main-nav a:hover,.main-nav a[aria-current="page"]{color:var(--blue)}.lang-link{border:1px solid var(--line);border-radius:999px;padding:8px 13px!important;background:#fff}.menu-button{display:none;border:0;background:transparent;padding:8px;cursor:pointer}.menu-button span{display:block;width:24px;height:2px;background:var(--navy);margin:5px 0;border-radius:2px}.hero{position:relative;overflow:hidden;padding:105px 0 90px;background:linear-gradient(145deg,#fff 0%,#f7faff 55%,#edfbfa 100%)}.hero:before,.hero:after{content:"";position:absolute;border-radius:50%;filter:blur(4px);pointer-events:none}.hero:before{width:520px;height:520px;right:-240px;top:-240px;background:radial-gradient(circle,rgba(18,201,192,.18),transparent 68%)}.hero:after{width:420px;height:420px;left:-220px;bottom:-260px;background:radial-gradient(circle,rgba(20,99,255,.14),transparent 70%)}.hero-grid{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(320px,.85fr);gap:64px;align-items:center;position:relative}.eyebrow{display:inline-flex;align-items:center;gap:8px;color:var(--blue);font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.eyebrow:before{content:"";width:24px;height:2px;background:linear-gradient(90deg,var(--blue),var(--teal))}.hero h1{margin:18px 0 22px;color:var(--navy);font-size:clamp(44px,6.4vw,78px);line-height:1.13;letter-spacing:-.055em}.hero h1 .accent{background:linear-gradient(90deg,var(--blue),var(--teal));-webkit-background-clip:text;background-clip:text;color:transparent}.hero-copy{max-width:720px;color:#40506A;font-size:18px}.actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:30px}.btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;min-height:50px;padding:12px 22px;border-radius:999px;border:1px solid var(--blue);font-weight:800;transition:.2s ease}.btn-primary{color:#fff;background:linear-gradient(110deg,var(--blue),#1689F5)}.btn-primary:hover{transform:translateY(-2px);box-shadow:0 14px 30px rgba(20,99,255,.25)}.btn-secondary{background:#fff;color:var(--navy);border-color:var(--line)}.btn-secondary:hover{border-color:var(--blue);color:var(--blue)}.hero-card{position:relative;padding:34px;border:1px solid rgba(221,230,241,.8);border-radius:30px;background:rgba(255,255,255,.85);box-shadow:var(--shadow)}.hero-card img{display:block;width:210px;margin:0 auto 28px;border-radius:42px;box-shadow:0 22px 45px rgba(11,31,68,.18)}.hero-card h2{margin:0 0 12px;color:var(--navy);font-size:24px;letter-spacing:-.02em}.check-list{list-style:none;padding:0;margin:18px 0 0}.check-list li{display:flex;gap:11px;margin:10px 0;color:#45546D}.check-list li:before{content:"✓";flex:none;width:22px;height:22px;border-radius:50%;display:grid;place-items:center;background:var(--soft-teal);color:#058E87;font-weight:900;font-size:13px}.trust-strip{background:var(--navy);color:#fff}.trust-grid{display:grid;grid-template-columns:repeat(4,1fr)}.trust-item{padding:22px;border-right:1px solid rgba(255,255,255,.14)}.trust-item:last-child{border-right:0}.trust-item strong{display:block;font-size:15px}.trust-item span{display:block;color:#B9C8E2;font-size:12px;margin-top:3px}.section{padding:88px 0}.section-white{background:#fff}.section-heading{display:flex;align-items:end;justify-content:space-between;gap:28px;margin-bottom:34px}.section-heading h2,.page-hero h1{margin:0;color:var(--navy);font-size:clamp(32px,4.5vw,54px);line-height:1.2;letter-spacing:-.045em}.section-heading p{max-width:560px;margin:0;color:var(--muted)}.grid{display:grid;gap:22px}.category-grid{grid-template-columns:repeat(5,1fr)}.card{position:relative;display:block;padding:27px;border:1px solid var(--line);border-radius:var(--radius);background:var(--surface);transition:.2s ease}.card:hover{transform:translateY(-4px);border-color:#BBD0FF;box-shadow:var(--shadow)}.card-icon{width:48px;height:48px;display:grid;place-items:center;border-radius:15px;background:linear-gradient(145deg,var(--soft-blue),var(--soft-teal));color:var(--blue);font-weight:900;font-size:18px}.card h3{margin:18px 0 8px;color:var(--navy);font-size:19px;line-height:1.35}.card p{margin:0;color:var(--muted);font-size:14px}.card .arrow{position:absolute;right:20px;top:20px;color:#8AA2C8}.feature-grid{grid-template-columns:repeat(3,1fr)}.feature{padding:30px;border-radius:var(--radius);background:#fff;border:1px solid var(--line)}.feature .number{font-size:12px;font-weight:900;color:var(--blue);letter-spacing:.1em}.feature h3{color:var(--navy);margin:10px 0}.feature p{margin:0;color:var(--muted)}.article-grid{grid-template-columns:repeat(3,1fr)}.article-card{overflow:hidden;padding:0}.article-visual{height:150px;padding:24px;background:linear-gradient(135deg,var(--navy),#123D7C);color:#fff}.article-visual.teal{background:linear-gradient(135deg,#064E58,#12AFA7)}.article-visual.blue{background:linear-gradient(135deg,#0D3F9D,#1463FF)}.article-card .content{padding:24px}.badge{display:inline-flex;padding:5px 10px;border-radius:999px;background:var(--soft-blue);color:var(--blue);font-size:11px;font-weight:800}.article-card h3{margin:14px 0 8px;color:var(--navy);font-size:20px}.article-card p{color:var(--muted);font-size:14px}.transparency{display:grid;grid-template-columns:1fr 1fr;gap:24px;padding:40px;border-radius:28px;background:linear-gradient(140deg,var(--navy),#102D63);color:#fff}.transparency h2{margin:0 0 12px;font-size:34px}.transparency p{color:#C7D5EC}.transparency .check-list li{color:#E3EDFC}.page-hero{padding:76px 0 52px;background:linear-gradient(145deg,#fff,#EFF5FF)}.breadcrumb{display:flex;gap:8px;flex-wrap:wrap;color:#6F7E94;font-size:13px;margin-bottom:18px}.page-lead{max-width:760px;color:#526078;font-size:17px}.content-section{padding:68px 0}.prose{font-size:16px}.prose h2{margin:48px 0 16px;color:var(--navy);font-size:30px;letter-spacing:-.025em}.prose h3{margin:32px 0 10px;color:var(--navy);font-size:21px}.prose p,.prose li{color:#43516A}.prose a{color:var(--blue);text-decoration:underline;text-underline-offset:3px}.prose ul,.prose ol{padding-left:1.35em}.notice{padding:22px 24px;border-left:4px solid var(--blue);border-radius:10px;background:var(--soft-blue);color:#33415A}.policy-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin:28px 0}.policy-card{padding:22px;border:1px solid var(--line);border-radius:18px;background:#fff}.policy-card strong{color:var(--navy)}.contact-card{display:grid;grid-template-columns:1fr auto;align-items:center;gap:24px;padding:32px;border:1px solid var(--line);border-radius:24px;background:#fff}.contact-card h2{margin-top:0;color:var(--navy)}.site-footer{padding:54px 0 28px;background:var(--navy-2);color:#fff}.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:50px}.footer-brand p{color:#AFC0DC;max-width:460px}.footer-title{font-weight:850;margin-bottom:14px}.footer-links{display:grid;gap:9px;color:#C5D1E4;font-size:14px}.footer-links a:hover{color:#fff}.footer-bottom{display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-top:42px;padding-top:22px;border-top:1px solid rgba(255,255,255,.12);color:#8FA3C2;font-size:12px}.language-page{min-height:100vh;display:grid;place-items:center;padding:40px;background:radial-gradient(circle at 80% 12%,rgba(18,201,192,.18),transparent 30%),radial-gradient(circle at 12% 85%,rgba(20,99,255,.16),transparent 35%),var(--navy-2)}.language-panel{width:min(94%,760px);padding:54px 38px;text-align:center;border:1px solid rgba(255,255,255,.13);border-radius:34px;background:rgba(255,255,255,.07);box-shadow:0 30px 80px rgba(0,0,0,.25);backdrop-filter:blur(16px);color:#fff}.language-panel img{width:150px;border-radius:34px;box-shadow:0 24px 50px rgba(0,0,0,.35)}.language-panel h1{font-size:clamp(46px,9vw,82px);margin:18px 0 0;letter-spacing:-.055em}.language-panel .tagline{color:#51DDD5;font-size:20px}.language-panel .actions{justify-content:center}.language-panel .btn-secondary{background:rgba(255,255,255,.08);color:#fff;border-color:rgba(255,255,255,.25)}.not-found{text-align:center;padding:120px 20px}.not-found .code{font-size:100px;color:var(--blue);font-weight:900;line-height:1}.cookie-banner{position:fixed;left:18px;right:18px;bottom:18px;z-index:2000;display:none;align-items:center;justify-content:space-between;gap:18px;max-width:960px;margin:auto;padding:18px 20px;border-radius:18px;background:#fff;box-shadow:0 20px 60px rgba(11,31,68,.25);border:1px solid var(--line)}.cookie-banner.show{display:flex}.cookie-banner p{margin:0;font-size:13px;color:#4B5970}.cookie-actions{display:flex;gap:8px;flex:none}.cookie-actions button{border:0;border-radius:999px;padding:9px 14px;font-weight:800;cursor:pointer}.cookie-accept{background:var(--blue);color:#fff}.cookie-decline{background:#EEF2F7;color:#33415A}
@media(max-width:1050px){.category-grid{grid-template-columns:repeat(3,1fr)}.hero-grid{grid-template-columns:1fr}.hero-card{max-width:620px}.trust-grid{grid-template-columns:repeat(2,1fr)}.trust-item:nth-child(2){border-right:0}.feature-grid,.article-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:760px){.header-inner{min-height:66px}.menu-button{display:block}.main-nav{position:absolute;left:4%;right:4%;top:72px;display:none;flex-direction:column;align-items:stretch;gap:0;padding:12px;border:1px solid var(--line);border-radius:18px;background:#fff;box-shadow:var(--shadow)}.main-nav.open{display:flex}.main-nav a{padding:12px}.hero{padding:72px 0 60px}.hero h1{font-size:44px}.hero-grid{gap:36px}.hero-card{padding:25px}.hero-card img{width:160px}.trust-grid{grid-template-columns:1fr}.trust-item{border-right:0;border-bottom:1px solid rgba(255,255,255,.14)}.section{padding:64px 0}.section-heading{display:block}.section-heading p{margin-top:12px}.category-grid,.feature-grid,.article-grid,.policy-grid{grid-template-columns:1fr}.transparency{grid-template-columns:1fr;padding:28px}.footer-grid{grid-template-columns:1fr;gap:30px}.contact-card{grid-template-columns:1fr}.language-panel{padding:38px 22px}.cookie-banner{display:none;flex-direction:column;align-items:stretch}.cookie-banner.show{display:flex}.cookie-actions{justify-content:flex-end}}
@media(prefers-reduced-motion:reduce){html{scroll-behavior:auto}*,*:before,*:after{transition:none!important;animation:none!important}}


/* v1.1 accessibility and performance refinements */
:focus-visible{outline:3px solid #F6B94A;outline-offset:3px;border-radius:4px}
.main-nav a[aria-current="page"]{font-weight:850}
.brand img{object-fit:cover;flex:none}
.footer-contact{margin:.4rem 0 0!important;font-size:14px}
.footer-contact a{color:#DCE8FA;text-decoration:underline;text-underline-offset:3px}
.footer-cookie-button{border:0;padding:0;background:transparent;color:#8FA3C2;font-size:12px;cursor:pointer;text-decoration:underline;text-underline-offset:3px}
.footer-cookie-button:hover{color:#fff}
.contact-options{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin:28px 0}
.contact-option{padding:22px;border:1px solid var(--line);border-radius:18px;background:#fff}
.contact-option h3{margin:0 0 8px;color:var(--navy);font-size:18px}
.contact-option p{margin:0 0 15px;font-size:14px}
.contact-option a{font-weight:800}
.cookie-banner[hidden]{display:none!important}
.cookie-banner{transition:opacity .18s ease,transform .18s ease;opacity:0;transform:translateY(8px)}
.cookie-banner.show{opacity:1;transform:translateY(0)}
@media(max-width:760px){.contact-options{grid-template-columns:1fr}.main-nav{max-height:calc(100vh - 92px);overflow:auto}}


/* v1.2 deployment, no-JS, and mobile interaction hardening */
body.menu-open{overflow:hidden}
html.no-js .menu-button{display:none}
@media(max-width:760px){
  html.no-js .header-inner{align-items:flex-start;flex-wrap:wrap;padding-block:12px}
  html.no-js .main-nav{position:static;display:flex;width:100%;max-height:none;box-shadow:none;border-radius:12px}
}
@media(min-width:761px){body.menu-open{overflow:auto}}
