{
  "name": "luqevora-static-platform",
  "version": "1.16.0",
  "private": true,
  "type": "module",
  "scripts": {
    "inventory": "node scripts/inventory.mjs",
    "import:legacy": "node scripts/import-legacy.mjs",
    "import:selected": "node scripts/import-selected-legacy.mjs",
    "audit:content": "node scripts/audit-content.mjs",
    "generate:seo-images": "node scripts/generate-seo-images.mjs",
    "build": "node scripts/build.mjs",
    "release:manifest": "node scripts/generate-release-manifest.mjs",
    "release:diff": "node scripts/prepare-release.mjs --baseline-url https://luqevora.com/release-manifest.json",
    "validate": "node scripts/validate.mjs",
    "check": "npm run audit:content && npm run generate:seo-images && npm run build && npm run release:manifest && npm run validate",
    "submit:indexnow": "node scripts/submit-indexnow.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
